# 投标 SaaS · 中间件接入变量模板
# 用法: 复制为 .env.bidsaas.local 并填入真实值(.local 已被 gitignore 忽略, 真实密码勿入库)
# 详见 docs/superpowers/specs/2026-06-24-bid-assistant-saas-architecture.md §14

# ===== PostgreSQL 16 + pgvector =====
PG_HOST=
PG_PORT=5432
PG_DB=bidsaas
PG_USER=bidsaas
PG_PASSWORD=
DATABASE_URL=
# schema: public(业务+账本) / langgraph(LangGraph checkpointer)

# ===== Redis (DB index + key 前缀做命名空间隔离) =====
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=3
REDIS_PASSWORD=
REDIS_KEY_PREFIX=bid:
# 注: 若密码含特殊/全角字符, 用分离参数连接, 不要拼进 redis:// URL

# ===== MinIO (S3 兼容) =====
MINIO_ENDPOINT=
MINIO_CONSOLE=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=bidsaas
MINIO_USE_SSL=false

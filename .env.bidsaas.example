# 投标 SaaS · 中间件接入变量模板
# 用法: 复制为 .env.bidsaas.local 并填入真实值(.local 已被 gitignore 忽略, 真实密码勿入库)
# 详见 docs/superpowers/specs/2026-06-24-bid-assistant-saas-architecture.md §14

# ===== PostgreSQL 16 + pgvector =====
PG_HOST=
PG_PORT=5432
PG_DB=bidsaas
PG_USER=bidsaas
PG_PASSWORD=
DATABASE_URL=
# schema: public(业务+账本) / langgraph(LangGraph checkpointer)

# ===== Redis (DB index + key 前缀做命名空间隔离) =====
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=3
REDIS_PASSWORD=
REDIS_KEY_PREFIX=bid:
# 注: 若密码含特殊/全角字符, 用分离参数连接, 不要拼进 redis:// URL

# Worker 并发执行 run 数上限，默认 5
AGENT_WORKER_CONCURRENCY=

# ===== MinIO (S3 兼容) =====
MINIO_ENDPOINT=
MINIO_PUBLIC_ENDPOINT= # 浏览器可达的 MinIO 地址(预签名用);内外一致时留空
MINIO_CONSOLE=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=bidsaas
MINIO_USE_SSL=false

# ===== 阿里云 AccessKey (短信服务 + 滑块验证码, 同一 RAM 账号 Key) =====
# 真实值填到 .env.bidsaas.local(勿入库); 短信与滑块可共用同一 AccessKey
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_CAPTCHA_ACCESS_KEY_ID=
ALIYUN_CAPTCHA_ACCESS_KEY_SECRET=
ALIYUN_CAPTCHA_SCENE_ID=

# ===== 阿里云邮件推送 DirectMail (spec332 发票开具通知; 凭据缺失自动回退 Fake 不真发) =====
# 需在阿里云控制台先「验证发信域名 + 创建发信地址」, ACCOUNT_NAME 填该已验证发信地址
# AccessKey 可复用短信那把 RAM 账号(需授予 DirectMail 权限), 或单独一把
ALIYUN_DM_ACCESS_KEY_ID=
ALIYUN_DM_ACCESS_KEY_SECRET=
ALIYUN_DM_ACCOUNT_NAME=
ALIYUN_DM_FROM_ALIAS=
# ALIYUN_DM_ENDPOINT 默认 dm.aliyuncs.com, 一般无需改

# ===== 收钱吧支付 (真实值只进 .env.bidsaas.local; 凭据缺失时支付路由/签到 Cron 自动跳过) =====
SQB_GATEWAY=https://vsi-api.shouqianba.com
SQB_VENDOR_SN=
SQB_VENDOR_KEY=
SQB_APP_ID=
SQB_ACTIVATION_CODE=
SQB_DEVICE_ID=
SQB_PUBLIC_KEY=
TERMINAL_KEY_SECRET=
PAYMENT_NOTIFY_BASE_URL=

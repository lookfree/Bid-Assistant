{
  "name": "@bid/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env.bidsaas.local run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun --env-file=../../.env.bidsaas.local run drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env.bidsaas.local run drizzle-kit migrate"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.5.1",
    "@alicloud/openapi-client": "^0.4.15",
    "drizzle-orm": "^0.36.0",
    "hono": "4.12.25",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "@types/bun": "latest"
  }
}
